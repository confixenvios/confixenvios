Table users {
  id uuid [pk]
  username varchar
  email varchar [unique]
  password_hash varchar
  first_name varchar
  last_name varchar
  phone varchar
  document varchar [not null]
  state_registration_number varchar
  status varchar [default: 'active']
  created_at timestamp [default: `now()`]
  updated_at timestamp [default: `now()`]
}

Table roles {
  id uuid [pk]
  name varchar [unique, not null]
  description varchar
  created_at timestamp [default: `now()`]
  updated_at timestamp [default: `now()`]
}

Table permissions {
  id uuid [pk]
  name varchar [unique, not null]
  description varchar
  created_at timestamp [default: `now()`]
  updated_at timestamp [default: `now()`]
}

Table user_roles {
  id uuid [pk]
  user_id uuid [ref: > users.id]
  role_id uuid [ref: > roles.id]
  created_at timestamp [default: `now()`]
  updated_at timestamp [default: `now()`]
}

Table role_permissions {
  id uuid [pk]
  role_id uuid [ref: > roles.id]
  permission_id uuid [ref: > permissions.id]
  created_at timestamp [default: `now()`]
  updated_at timestamp [default: `now()`]
}

Table carriers {
  id uuid [pk]
  name varchar [unique, not null]
  code varchar [unique, not null]
  cnpj varchar
  is_active boolean [default: true]
  created_at timestamp [default: `now()`]
  updated_at timestamp [default: `now()`]
}

Table addresses {
  id uuid [pk]
  cep varchar
  street varchar
  number varchar
  complement varchar
  district varchar
  city varchar
  state varchar
  reference varchar
  created_at timestamp [default: `now()`]
  updated_at timestamp [default: `now()`]
}

Table saved_contacts {
  id uuid [pk]
  user_id uuid [ref: > users.id]
  address_id uuid [ref: > addresses.id]
  contact_type varchar
  name varchar
  document varchar
  document_type varchar
  phone varchar
  email varchar
  is_default boolean [default: false]
  created_at timestamp [default: `now()`]
  updated_at timestamp [default: `now()`]
}

Table orders {
  id uuid [pk]
  user_id uuid [ref: > users.id]
  carrier_id uuid [ref: > carriers.id]
  is_sender_address boolean [not null]
  pickup_driver_id uuid [ref: > users.id, null]
  tracking_code varchar [unique]
  status varchar [default: 'PENDING']
  origin varchar
  document_type varchar
  selected_option varchar
  pickup_option varchar
  format varchar
  pricing_table_name varchar
  quote_data jsonb
  payment_data jsonb
  label_pdf_url varchar
  carrier_barcode varchar
  carrier_order_id varchar
  address_sender_id uuid [ref: > addresses.id]
  address_recipient_id uuid [ref: > addresses.id]
  address_pickup_id uuid [ref: > addresses.id, null]
  created_at timestamp [default: `now()`]
  updated_at timestamp [default: `now()`]
}

Table packages {
  id uuid [pk]
  order_id uuid [ref: > orders.id]
  delivery_driver_id uuid [ref: > users.id, null]
  package_number integer [unique]
  external_label_code varchar [unique]
  status varchar [default: 'PENDING']
  weight decimal
  length decimal
  width decimal
  height decimal
  delivery_photo_url varchar
  created_at timestamp [default: `now()`]
  updated_at timestamp [default: `now()`]
}

Table package_events {
  id uuid [pk]
  package_id uuid [ref: > packages.id]
  created_by uuid [ref: > users.id]
  pickup_driver_id uuid [ref: > users.id, null]
  delivery_driver_id uuid [ref: > users.id, null]
  event_type varchar
  status varchar
  description varchar
  notes varchar
  metadata jsonb
  is_alert boolean [default: false]
  created_at timestamp [default: `now()`]
}

Table fiscal_documents {
  id uuid [pk]
  order_id uuid [ref: > orders.id]
  document_type varchar
  document_key varchar [unique]
  document_number varchar
  series varchar
  status varchar
  reason varchar
  xml_url varchar
  pdf_url varchar
  raw_payload jsonb
  is_contingency boolean [default: false]
  created_at timestamp [default: `now()`]
  updated_at timestamp [default: `now()`]
}

Table temp_quote {
  id uuid [pk]
  user_id uuid [ref: > users.id, null]
  session_id varchar
  origin_cep varchar
  destination_cep varchar
  total_weight decimal
  total_volume decimal
  packages_data jsonb
  quote_options jsonb
  status varchar [default: 'active']
  expires_at timestamp
  created_at timestamp [default: `now()`]
  updated_at timestamp [default: `now()`]
}
